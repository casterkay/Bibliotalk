# Google Gemini key used for Gemini model calls
GOOGLE_API_KEY=

# Supabase project URL and service role key
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# EverMemOS base endpoint, e.g. http://localhost:8000
EMOS_BASE_URL=
EMOS_API_KEY=
EMOS_ORG_ID=
EMOS_SPACE_ID=

# AWS region for Bedrock-backed models (default us-east-1)
AWS_REGION=us-east-1

# Matrix homeserver + appservice tokens
MATRIX_HOMESERVER_URL=
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=

# Structured logging level
LOG_LEVEL=INFO
