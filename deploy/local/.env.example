# Copy this file to deploy/local/.env and fill in your values.

EMOS_BASE_URL=https://your-evermemos-instance.example.com
EMOS_API_KEY=replace-me
GOOGLE_API_KEY=replace-me
BIBLIOTALK_DB_PATH=/data/bibliotalk.db
LOG_LEVEL=INFO
BIBLIOTALK_WEB_URL=https://www.bibliotalk.space

# Agent slug used by the memory service in a one-agent local stack.
BIBLIOTALK_AGENT=alan-watts

# Discord bot token (single-bot runtime).
DISCORD_TOKEN=replace-me

# Optional: sync slash commands to a single guild for fast iteration.
DISCORD_COMMAND_GUILD_ID=
DISCORD_VOICE_DEFAULT_TEXT_CHANNEL_ID=

# In local compose, discord -> voip -> agents.
VOIP_SERVICE_URL=http://voip:9012
AGENTS_SERVICE_URL=http://agents:8009

# Optional: enable Gemini-based facilitator/concierge (defaults to deterministic fallback).
BIBLIOTALK_ENABLE_AI_ROUTER=
BIBLIOTALK_ENABLE_AI_CONCIERGE=

# Optional Memories API bind settings.
MEMORIES_HOST=0.0.0.0
MEMORIES_PORT=8080

# Matrix homeserver + appservice tokens (local stack)
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=
MATRIX_SENDER_LOCALPART=bt_system
MATRIX_SPIRIT_USER_PREFIX=bt_

# Synapse + Element dev ports & provisioning
MATRIX_SERVER_NAME=localhost
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=
MATRIX_REGISTRATION_SHARED_SECRET=
SYNAPSE_PORT=8008
ELEMENT_PORT=8081

# Optional: Synapse proxy env (used by deploy/local/matrix/docker-compose.yml)
MATRIX_HTTP_PROXY=
MATRIX_HTTPS_PROXY=
MATRIX_NO_PROXY=localhost,127.0.0.1

# Voice (Gemini Live). Use a low-latency native-audio model.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# VOIP runtime (Node 22 in local compose)
VOIP_SERVICE_HOST=0.0.0.0
VOIP_SERVICE_PORT=9012
