# Copy to `.env` (at repo root or deploy/local/.env) and fill in your values.

# =============================================================================
# EverMemOS
# =============================================================================
EMOS_BASE_URL=https://your-evermemos-instance.example.com
EMOS_API_KEY=replace-me

# =============================================================================
# Gemini (Google ADK)
# =============================================================================
GOOGLE_API_KEY=replace-me

# =============================================================================
# Discord
# =============================================================================
# Discord bot token (single-bot runtime)
DISCORD_TOKEN=replace-me

# Optional: sync slash commands to a single guild for fast iteration
DISCORD_COMMAND_GUILD_ID=
DISCORD_VOICE_DEFAULT_TEXT_CHANNEL_ID=

# =============================================================================
# Agent & Memory Settings
# =============================================================================
# Agent slug used by the memory service in a one-agent local stack
BIBLIOTALK_AGENT=alan-watts

# Optional: enable Gemini-based facilitator/concierge (defaults to deterministic fallback)
BIBLIOTALK_ENABLE_AI_ROUTER=
BIBLIOTALK_ENABLE_AI_CONCIERGE=

# =============================================================================
# Database & Web
# =============================================================================
# SQLite database path (for local dev, leave empty for default ~/.bibliotalk/bibliotalk.db)
# For Docker compose, use: /data/bibliotalk.db
BIBLIOTALK_DB_PATH=/data/bibliotalk.db

# Public base URL used in inline memory links
BIBLIOTALK_WEB_URL=https://www.bibliotalk.space

# Structured logging level
LOG_LEVEL=INFO

# Admin token (required for the operator console + protected Memories API ops endpoints)
BIBLIOTALK_ADMIN_TOKEN=

# =============================================================================
# Memories API (optional)
# =============================================================================
MEMORIES_HOST=0.0.0.0
MEMORIES_PORT=8080

# =============================================================================
# Operator Console (optional)
# =============================================================================
# Next.js dev server port (see deploy/local/docker-compose.yml)
CONSOLE_PORT=3000

# Console -> Memories API base URL (for local dev use http://localhost:8080)
MEMORIES_SERVICE_URL=http://memories:8080

# =============================================================================
# Service URLs (for local dev use localhost, for Docker compose use service names)
# =============================================================================
# agents_service base URL (called by matrix_service)
# Local: http://localhost:8009 | Docker: http://agents:8009
AGENTS_SERVICE_URL=http://agents:8009

# voip_service base URL (called by matrix_service)
# Local: http://localhost:9012 | Docker: http://voip:9012
VOIP_SERVICE_URL=http://voip:9012

# MatrixRTC focus URL fallback (used when call events omit foci_preferred)
VOIP_LIVEKIT_SERVICE_URL=http://localhost/livekit/jwt

# =============================================================================
# Voice (Gemini Live)
# =============================================================================
# Model selection for agents_service voice sessions
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# VOIP runtime (Node 22 in local compose)
VOIP_SERVICE_HOST=0.0.0.0
VOIP_SERVICE_PORT=9012

# =============================================================================
# Matrix
# =============================================================================
# Matrix homeserver + appservice tokens
MATRIX_HOMESERVER_URL=http://localhost:8008
MATRIX_AS_TOKEN=
MATRIX_HS_TOKEN=
MATRIX_SENDER_LOCALPART=bt_system
MATRIX_SPIRIT_USER_PREFIX=bt_

# Synapse admin (for scripted local provisioning)
MATRIX_SERVER_NAME=localhost
MATRIX_ADMIN_USER=admin
MATRIX_ADMIN_PASSWORD=
MATRIX_REGISTRATION_SHARED_SECRET=
SYNAPSE_PORT=8008
ELEMENT_PORT=8081

# Optional: Synapse proxy env (used by deploy/local/matrix/docker-compose.yml)
MATRIX_HTTP_PROXY=
MATRIX_HTTPS_PROXY=
MATRIX_NO_PROXY=localhost,127.0.0.1

# =============================================================================
# Proxy (optional)
# =============================================================================
# If Discord is only reachable via proxy, export standard proxy env vars.
# Example (Clash default):
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890
